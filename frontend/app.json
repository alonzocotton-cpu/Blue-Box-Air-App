{
  "expo": {
    "name": "Blue Box Air, Inc.",
    "slug": "blue-box-air-inc",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.jpeg",
    "scheme": "blueboxairtech",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "owner": "blueboxair",
    "description": "Blue Box Air, Inc. Technician App — Coil management, equipment service readings, project reports, and team collaboration for field technicians.",
    "githubUrl": "",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.blueboxair.techapp",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Capture equipment photos and record service videos",
        "NSPhotoLibraryUsageDescription": "Upload photos and videos from your gallery",
        "NSMicrophoneUsageDescription": "Record audio with equipment service videos",
        "NSLocationWhenInUseUsageDescription": "Track your location for service visits",
        "NSLocationAlwaysUsageDescription": "Track location during service visits",
        "NSFaceIDUsageDescription": "Use Face ID to quickly login to the app",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.jpeg",
        "backgroundColor": "#0f2744"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.blueboxair.techapp",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/logo.jpeg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo.jpeg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0f2744"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Blue Box Air, Inc Tech App to use Face ID for quick login"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    },
    "updates": {
      "url": ""
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
